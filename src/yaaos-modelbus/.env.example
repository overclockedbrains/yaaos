# YAAOS Model Bus — environment configuration
# Copy to .env and fill in your values.
# .env is gitignored — secrets stay local.

# ── Socket path (used by both daemon and CLI) ──
# YAAOS_MODELBUS_SOCKET=/tmp/yaaos-modelbus.sock

# ── API keys (required for cloud providers) ──
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=pa-...

# ── Ollama (if running on a different host/port) ──
# OLLAMA_HOST=http://localhost:11434
